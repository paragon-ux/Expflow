{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/adapter-project-revision.schema.json",
  "title": "Opaque Adapter Project Revision Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "adapter_revision_id",
    "project_ref",
    "previous_adapter_revision_id",
    "material_head",
    "semantic_sequence",
    "authority_sequence",
    "manifest_heads_digest",
    "automation_sequence",
    "created_at",
    "trigger_refs",
    "state_digest"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "adapter_revision_id": {
      "type": "string",
      "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_ref": {
      "type": "string"
    },
    "previous_adapter_revision_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "material_head": {
      "type": [
        "string",
        "null"
      ]
    },
    "semantic_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "authority_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "manifest_heads_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "automation_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "trigger_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "state_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
