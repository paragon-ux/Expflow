{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/protocol-response.schema.json",
  "title": "Adapter Protocol Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "request_id",
    "profile",
    "operation",
    "status",
    "adapter_revision",
    "result",
    "warnings",
    "error"
  ],
  "properties": {
    "protocol_version": {
      "const": "1.0"
    },
    "request_id": {
      "type": "string",
      "pattern": "^egr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "profile": {
      "const": "expflow.relative-tree.v1"
    },
    "operation": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "no_change",
        "requires_review",
        "rejected",
        "partial",
        "failed",
        "unknown"
      ]
    },
    "adapter_revision": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "result": {},
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "recoverable"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "recoverable": {
          "type": "boolean"
        },
        "recommended_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
