{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/operation-outcome.schema.json",
  "title": "Adapter Operation Outcome",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "outcome_id",
    "attempt_id",
    "status",
    "material_outcome",
    "automation_outcome",
    "adapter_revision_id",
    "completed_at",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "outcome_id": {
      "type": "string",
      "pattern": "^ego_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "attempt_id": {
      "type": "string",
      "pattern": "^ega_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "partial",
        "rejected",
        "failed",
        "unknown"
      ]
    },
    "material_outcome": {
      "type": "string",
      "enum": [
        "committed",
        "not_committed",
        "unknown"
      ]
    },
    "automation_outcome": {
      "type": "string",
      "enum": [
        "complete",
        "incomplete",
        "not_applicable",
        "unknown"
      ]
    },
    "adapter_revision_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "core_operation_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "retryable": {
      "type": "boolean"
    }
  }
}
