# Normalize line endings for text files
* text=auto

# These files are always LF in the repo
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf

# Immutable architecture sources are byte-preserved inputs.
docs/architecture/** -text -eol

# Binary
*.png binary
*.jpg binary
*.ico binary
