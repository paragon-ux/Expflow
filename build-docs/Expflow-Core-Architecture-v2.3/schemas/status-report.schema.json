{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/status-report.schema.json",
  "title": "Integrated Project Status Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "head_tree_revision_id",
    "working_tree_state",
    "generated_at",
    "unresolved_items",
    "manifest_heads",
    "automation_state"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "head_tree_revision_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "working_tree_state": {
      "type": "string",
      "enum": [
        "clean",
        "drifted",
        "invalid",
        "uninitialized"
      ]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "pending_changes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "unresolved_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_conflict_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_request_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow_occurrence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manifest_heads": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "manifest_revision_ref",
          "status"
        ],
        "properties": {
          "manifest_revision_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "absent",
              "current",
              "proposed",
              "stale",
              "conflicted"
            ]
          }
        }
      }
    },
    "automation_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pending_hooks",
        "failed_hooks"
      ],
      "properties": {
        "pending_hooks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed_hooks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "recommended_action": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
