{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/operation-recovery-event.schema.json",
  "title": "Adapter Operation Recovery Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "recovery_event_id",
    "attempt_id",
    "recovery_class",
    "observed_at",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "recovery_event_id": {
      "type": "string",
      "pattern": "^egrc_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "attempt_id": {
      "type": "string",
      "pattern": "^ega_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "recovery_class": {
      "type": "string",
      "enum": [
        "lost_response",
        "core_commit_found",
        "core_commit_not_found",
        "automation_incomplete",
        "replay_returned_original",
        "evidence_insufficient"
      ]
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
