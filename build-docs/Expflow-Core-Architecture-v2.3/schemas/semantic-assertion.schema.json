{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/semantic-assertion.schema.json",
  "title": "Attributed Semantic Assertion",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "assertion_id",
    "project_id",
    "issuer",
    "assertion_type",
    "created_at",
    "subject_refs",
    "claims",
    "limitations"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "assertion_id": {
      "type": "string",
      "pattern": "^efa_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "tree_revision_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "workflow_occurrence_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^efw_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "policy",
            "integration",
            "model",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "assertion_type": {
      "type": "string",
      "enum": [
        "role_proposal",
        "cluster_proposal",
        "workflow_boundary",
        "materialization_link",
        "semantic_drift",
        "source_correspondence",
        "completion_declaration",
        "reuse_fit",
        "custom"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "subject_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "input_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "predicate",
          "value"
        ],
        "properties": {
          "predicate": {
            "type": "string"
          },
          "value": {},
          "confidence": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0,
            "maximum": 1
          },
          "explanation": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "content_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  }
}
