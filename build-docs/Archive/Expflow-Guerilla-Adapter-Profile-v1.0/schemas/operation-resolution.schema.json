{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/operation-resolution.schema.json",
  "title": "Adapter Operation Resolution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_ref",
    "query_kind",
    "query_value",
    "attempt_refs",
    "outcome_refs",
    "recovery_event_refs",
    "classification",
    "resolved_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "project_ref": {
      "type": "string"
    },
    "query_kind": {
      "type": "string",
      "enum": [
        "attempt_id",
        "idempotency_key",
        "request_digest"
      ]
    },
    "query_value": {
      "type": "string"
    },
    "attempt_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outcome_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recovery_event_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "classification": {
      "type": "string",
      "enum": [
        "committed_complete",
        "committed_automation_incomplete",
        "not_committed",
        "rejected",
        "failed",
        "unknown",
        "idempotency_conflict",
        "history_expired"
      ]
    },
    "adapter_revision_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolved_at": {
      "type": "string",
      "format": "date-time"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
