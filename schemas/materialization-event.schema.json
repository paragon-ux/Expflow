{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/materialization-event.schema.json",
  "title": "Virtual-to-Material Materialization Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "materialization_event_id",
    "project_id",
    "virtual_artifact_id",
    "material_node_ref",
    "event_kind",
    "asserted_by",
    "occurred_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "materialization_event_id": {
      "type": "string",
      "pattern": "^efme_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "virtual_artifact_id": {
      "type": "string",
      "pattern": "^efva_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "material_node_ref": {
      "type": "string"
    },
    "event_kind": {
      "type": "string",
      "enum": [
        "download",
        "copy",
        "convert",
        "external_save",
        "regenerate",
        "import"
      ]
    },
    "asserted_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "policy",
            "integration",
            "model",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "authority_source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
