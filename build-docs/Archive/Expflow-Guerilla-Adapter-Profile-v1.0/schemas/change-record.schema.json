{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/change-record.schema.json",
  "title": "Adapter Change Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "change_id",
    "project_ref",
    "adapter_revision_id",
    "sequence",
    "change_type",
    "record_family",
    "record_ref",
    "occurred_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "change_id": {
      "type": "string",
      "pattern": "^egc_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_ref": {
      "type": "string"
    },
    "adapter_revision_id": {
      "type": "string",
      "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "sequence": {
      "type": "integer",
      "minimum": 1
    },
    "change_type": {
      "type": "string",
      "enum": [
        "created",
        "superseded",
        "head_promoted",
        "status_changed",
        "recovery_appended"
      ]
    },
    "record_family": {
      "type": "string"
    },
    "record_ref": {
      "type": "string"
    },
    "source_digest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
