{
  "name": "expflow",
  "version": "0.0.0-phase.1",
  "private": true,
  "description": "Expflow - schema-governed, local-first workflow ownership and observability platform",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "expflow": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "format": "prettier --write \"**/*.{ts,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,mjs,json,md}\"",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "contracts:verify": "tsx tests/contracts/verify.ts",
    "controls:generate": "tsx tests/contracts/generate-controls.ts",
    "registries:verify": "tsx tests/contracts/registries-verify.ts",
    "schemas:meta-validate": "tsx tests/contracts/meta-validate.ts",
    "schemas:examples-validate": "tsx tests/contracts/schema-example-validate.ts",
    "examples:index-check": "tsx tests/contracts/examples-index-check.ts",
    "fixtures:verify": "tsx tests/contracts/fixtures-verify.ts",
    "package:verify": "tsx tests/contracts/package-verify.ts",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm test && npm run contracts:verify && npm run registries:verify && npm run schemas:meta-validate && npm run examples:index-check && npm run schemas:examples-validate && npm run fixtures:verify && npm run build && npm run package:verify"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.23.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "schemas/",
    "docs/architecture/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/paragon-ux/Expflow.git"
  },
  "license": "UNLICENSED"
}
