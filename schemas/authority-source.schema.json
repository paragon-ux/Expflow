{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/authority-source.schema.json",
  "title": "Extensible Authority Source Revision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "source_revision",
    "source_type",
    "issuer",
    "origin",
    "schema_uri",
    "schema_version_declared",
    "subject_scope",
    "fact_scope",
    "readable_representation",
    "limitations",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "source_id": {
      "type": "string",
      "pattern": "^efs_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "source_revision": {
      "type": "integer",
      "minimum": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "issuer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "policy",
            "integration",
            "model",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "origin": {
      "type": "string",
      "minLength": 1
    },
    "schema_uri": {
      "type": "string",
      "format": "uri-reference"
    },
    "schema_version_declared": {
      "type": "string",
      "minLength": 1
    },
    "subject_scope": {
      "$ref": "path-selector.schema.json"
    },
    "fact_scope": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "effective_interval": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "end": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "readable_representation": {
      "type": "string",
      "minLength": 1
    },
    "machine_representation": {
      "type": [
        "string",
        "null"
      ]
    },
    "content_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handling_labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license_expression": {
      "type": [
        "string",
        "null"
      ]
    },
    "reuse_restrictions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "supersedes_source_revision_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
