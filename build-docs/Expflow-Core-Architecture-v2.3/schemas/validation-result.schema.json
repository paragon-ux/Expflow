{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/validation-result.schema.json",
  "title": "Validation Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "validation_id",
    "operation_id",
    "validator",
    "status",
    "blocking",
    "checked_at",
    "findings"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "validation_id": {
      "type": "string",
      "pattern": "^efv_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "operation_id": {
      "type": "string",
      "pattern": "^efo_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "validator": {
      "type": "string",
      "minLength": 1
    },
    "validator_version": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail",
        "error"
      ]
    },
    "blocking": {
      "type": "boolean"
    },
    "checked_at": {
      "type": "string",
      "format": "date-time"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "relative_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "details": {
            "type": [
              "object",
              "null"
            ]
          }
        }
      }
    }
  }
}
