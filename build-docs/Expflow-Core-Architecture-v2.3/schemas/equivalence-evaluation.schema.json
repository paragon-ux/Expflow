{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/equivalence-evaluation.schema.json",
  "title": "Regeneration or Workflow Equivalence Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evaluation_id",
    "project_id",
    "subject_ref",
    "evaluator",
    "classification",
    "evidence_refs",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "evaluation_id": {
      "type": "string",
      "pattern": "^efee_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "subject_ref": {
      "type": "string"
    },
    "reference_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evaluator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "policy",
            "integration",
            "model",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "classification": {
      "type": "string",
      "enum": [
        "exact",
        "representation_equivalent",
        "workflow_equivalent",
        "divergent",
        "incomplete",
        "failed"
      ]
    },
    "metrics": {
      "type": "object"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "acceptance_decision_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
