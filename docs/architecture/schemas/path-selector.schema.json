{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/path-selector.schema.json",
  "title": "Path Selector",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "include",
    "exclude"
  ],
  "properties": {
    "include": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "**/*"
      ]
    },
    "exclude": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "root": {
      "type": "string",
      "default": "."
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
