{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/conflict.schema.json",
  "title": "Immutable Conflict Declaration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "conflict_id",
    "project_id",
    "subject_refs",
    "competing_claim_refs",
    "authority_scope",
    "severity",
    "declared_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "conflict_id": {
      "type": "string",
      "pattern": "^efc_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "subject_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "competing_claim_refs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      }
    },
    "authority_scope": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "informational",
        "review",
        "blocking"
      ]
    },
    "declared_at": {
      "type": "string",
      "format": "date-time"
    },
    "review_request_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
