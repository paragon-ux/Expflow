{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/artifact-cluster.schema.json",
  "title": "Derived Artifact Cluster View",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cluster_id",
    "project_id",
    "proposal_refs",
    "member_refs",
    "evidence_refs",
    "decision_refs",
    "derived_state",
    "computed_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "cluster_id": {
      "type": "string",
      "pattern": "^efcl_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "proposal_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "member_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "derived_state": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "ambiguous",
        "conflicted",
        "rejected",
        "superseded"
      ]
    },
    "logical_label": {
      "type": [
        "string",
        "null"
      ]
    },
    "computed_at": {
      "type": "string",
      "format": "date-time"
    },
    "decision_head": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
