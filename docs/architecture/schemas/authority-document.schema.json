{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/authority-document.schema.json",
  "title": "Readable Authority Document Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "document_id",
    "project_id",
    "profile",
    "readable_locator",
    "content_digest",
    "sections",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "document_id": {
      "type": "string",
      "pattern": "^efad_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "profile": {
      "type": "string",
      "enum": [
        "split",
        "unified"
      ]
    },
    "readable_locator": {
      "type": "string",
      "minLength": 1
    },
    "content_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "machine_sidecar_locator": {
      "type": [
        "string",
        "null"
      ]
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "anchor",
          "authority_role",
          "source_revision_refs"
        ],
        "properties": {
          "anchor": {
            "type": "string",
            "minLength": 1
          },
          "authority_role": {
            "type": "string",
            "enum": [
              "chat_actual_artifact_history",
              "llm_artifact_assertion",
              "user_provided_event_history",
              "registered_authority_source"
            ]
          },
          "source_revision_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "const": "split"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "sections": {
            "maxItems": 1
          }
        }
      }
    }
  ]
}
