{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/operation-plan.schema.json",
  "title": "Expflow Operation Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation_id",
    "project_id",
    "operation_type",
    "requested_at",
    "requested_by",
    "expected_head",
    "scope",
    "changes",
    "automation"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "operation_id": {
      "type": "string",
      "pattern": "^efo_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "operation_type": {
      "type": "string",
      "enum": [
        "init",
        "sync",
        "restore"
      ]
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "policy",
            "integration",
            "model",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "expected_head": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "scope": {
      "$ref": "path-selector.schema.json"
    },
    "changed_path_hints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "path",
          "identity_directive"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "add",
              "modify",
              "move",
              "delete",
              "restore",
              "materialize_projection"
            ]
          },
          "path": {
            "type": "string"
          },
          "from_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "identity_directive": {
            "type": "string",
            "enum": [
              "auto",
              "preserve",
              "new",
              "replace"
            ]
          },
          "node_id": {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^efn_[0-9A-HJKMNP-TV-Z]{26}$"
              },
              {
                "type": "null"
              }
            ]
          },
          "node_revision": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "basis_note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "authority_source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow_hints": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_structural_validation",
        "run_semantic_assertions",
        "detect_workflows",
        "project_manifests"
      ],
      "properties": {
        "run_structural_validation": {
          "type": "boolean"
        },
        "run_semantic_assertions": {
          "type": "boolean"
        },
        "detect_workflows": {
          "type": "boolean"
        },
        "project_manifests": {
          "type": "boolean"
        },
        "semantic_refresh_on_no_change": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
