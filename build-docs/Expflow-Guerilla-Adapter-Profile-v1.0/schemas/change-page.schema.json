{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/change-page.schema.json",
  "title": "Incremental Adapter Change Page",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_ref",
    "from_cursor",
    "changes",
    "next_cursor",
    "adapter_revision_id",
    "has_more"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "project_ref": {
      "type": "string"
    },
    "from_cursor": {
      "type": [
        "string",
        "null"
      ]
    },
    "changes": {
      "type": "array",
      "items": {
        "$ref": "change-record.schema.json"
      }
    },
    "next_cursor": {
      "type": "string",
      "pattern": "^egcur_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "adapter_revision_id": {
      "type": "string",
      "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "has_more": {
      "type": "boolean"
    },
    "cursor_expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
