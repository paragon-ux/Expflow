{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/tree-entry.schema.json",
  "title": "Tree Path Occupancy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "relative_path",
    "entry_kind",
    "occupancy_status"
  ],
  "properties": {
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(^/)|(^|/)\\.\\.(/|$)|\\\\"
      }
    },
    "entry_kind": {
      "type": "string",
      "enum": [
        "file",
        "directory",
        "external_reference"
      ]
    },
    "node_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^efn_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "node_revision": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "external_locator": {
      "type": [
        "string",
        "null"
      ]
    },
    "folder_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "filename": {
      "type": [
        "string",
        "null"
      ]
    },
    "occupancy_status": {
      "type": "string",
      "enum": [
        "present",
        "historical",
        "missing",
        "external"
      ]
    },
    "node_content_digest": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "entry_kind": {
            "const": "file"
          }
        },
        "required": [
          "entry_kind"
        ]
      },
      "then": {
        "required": [
          "node_id",
          "node_revision",
          "filename",
          "node_content_digest"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "entry_kind": {
            "const": "external_reference"
          }
        },
        "required": [
          "entry_kind"
        ]
      },
      "then": {
        "required": [
          "external_locator"
        ]
      }
    }
  ]
}
