{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/operation-attempt.schema.json",
  "title": "Adapter Operation Attempt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "attempt_id",
    "project_ref",
    "operation_family",
    "idempotency_key",
    "request_digest",
    "request_canonicalization_profile",
    "expected_adapter_revision",
    "actor",
    "started_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "attempt_id": {
      "type": "string",
      "pattern": "^ega_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_ref": {
      "type": "string"
    },
    "operation_family": {
      "type": "string"
    },
    "idempotency_key": {
      "type": "string"
    },
    "request_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "request_canonicalization_profile": {
      "const": "expflow-guerilla-jcs-v1"
    },
    "expected_adapter_revision": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "integration",
            "system",
            "policy"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "core_operation_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
