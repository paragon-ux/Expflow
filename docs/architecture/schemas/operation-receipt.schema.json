{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/operation-receipt.schema.json",
  "title": "Operation Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation_id",
    "project_id",
    "status",
    "started_at",
    "finished_at",
    "validation_refs",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "operation_id": {
      "type": "string",
      "pattern": "^efo_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "committed",
        "no_change",
        "rejected",
        "partial_post_commit",
        "failed"
      ]
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "previous_head": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "new_head": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "node_revision_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assertion_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manifest_revision_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "workflow_occurrence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "recoverable"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "recoverable": {
          "type": "boolean"
        },
        "recommended_action": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
