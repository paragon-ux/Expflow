{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/project.schema.json",
  "title": "Expflow Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_id",
    "root_path",
    "created_at",
    "head_tree_revision_id",
    "projection_root",
    "managed_exclusions"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "root_path": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "head_tree_revision_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "projection_root": {
      "const": ".expflow/projections"
    },
    "managed_exclusions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "contains": {
        "const": ".expflow/**"
      }
    },
    "policy_profile": {
      "type": "string",
      "default": "default"
    },
    "hook_profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "authority_document_profile": {
      "type": "string",
      "enum": [
        "split",
        "unified",
        "mixed"
      ]
    },
    "current_manifest_heads": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": "string",
            "pattern": "^efm_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          {
            "type": "null"
          }
        ]
      }
    }
  }
}
