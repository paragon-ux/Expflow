{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/review-request.schema.json",
  "title": "Review Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_request_id",
    "project_id",
    "subject_refs",
    "requested_action",
    "blocking",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "review_request_id": {
      "type": "string",
      "pattern": "^efrr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "subject_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "requested_action": {
      "type": "string",
      "minLength": 1
    },
    "blocking": {
      "type": "boolean"
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_by": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "policy",
            "integration",
            "model",
            "system"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "resolved_by_decision_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
