{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/regeneration-attempt.schema.json",
  "title": "Regeneration Attempt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "regeneration_attempt_id",
    "project_id",
    "target_kind",
    "source_workflow_occurrence_id",
    "input_tree_revision_id",
    "model_profile",
    "prompt_digest",
    "tool_profile",
    "status",
    "started_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "regeneration_attempt_id": {
      "type": "string",
      "pattern": "^efra_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "target_kind": {
      "type": "string",
      "enum": [
        "artifact",
        "workflow"
      ]
    },
    "target_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_workflow_occurrence_id": {
      "type": "string",
      "pattern": "^efw_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "input_tree_revision_id": {
      "type": "string",
      "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "model_profile": {
      "type": "string"
    },
    "prompt_digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "tool_profile": {
      "type": "string"
    },
    "security_profile": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "unknown",
        "cancelled"
      ]
    },
    "output_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "failure": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
