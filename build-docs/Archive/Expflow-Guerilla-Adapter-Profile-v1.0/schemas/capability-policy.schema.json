{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/capability-policy.schema.json",
  "title": "Adapter Capability Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "profile",
    "capabilities",
    "writer_partition",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "policy_id": {
      "type": "string",
      "pattern": "^egp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "profile": {
      "const": "expflow.relative-tree.v1"
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "inspect",
        "changes",
        "operation_resolve",
        "init",
        "observational_sync",
        "mutating_sync",
        "restore",
        "projection_materialization",
        "regeneration",
        "equivalence_evaluation"
      ],
      "properties": {
        "inspect": {
          "type": "boolean"
        },
        "changes": {
          "type": "boolean"
        },
        "operation_resolve": {
          "type": "boolean"
        },
        "init": {
          "type": "boolean"
        },
        "observational_sync": {
          "type": "boolean"
        },
        "mutating_sync": {
          "type": "boolean"
        },
        "restore": {
          "type": "boolean"
        },
        "projection_materialization": {
          "type": "boolean"
        },
        "regeneration": {
          "type": "boolean"
        },
        "equivalence_evaluation": {
          "type": "boolean"
        }
      }
    },
    "writer_partition": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "boundary",
          "primary_writer",
          "adapter_access"
        ],
        "properties": {
          "boundary": {
            "type": "string"
          },
          "primary_writer": {
            "type": "string"
          },
          "adapter_access": {
            "type": "string"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
