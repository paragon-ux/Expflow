{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/inspection-request.schema.json",
  "title": "Revision-Bound Inspection Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "project_ref",
    "at_revision",
    "include",
    "page_size"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "project_ref": {
      "type": "string"
    },
    "at_revision": {
      "type": "string",
      "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "trees",
          "nodes",
          "operations",
          "authority_sources",
          "authority_decisions",
          "assertions",
          "semantic_decisions",
          "conflicts",
          "workflows",
          "manifests",
          "regeneration",
          "evaluations",
          "reuse",
          "automation"
        ]
      },
      "uniqueItems": true
    },
    "workflow_occurrence_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "record_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "page_size": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "page_token": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
