{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/adapter-profile.schema.json",
  "title": "Expflow Guerilla Adapter Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile",
    "compatible_expflow_core",
    "continuity_mode",
    "identity_model",
    "revision_model",
    "consistency",
    "observe",
    "act",
    "evaluate",
    "reconcile",
    "unknown_outcomes",
    "writer_partition"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "profile": {
      "const": "expflow.relative-tree.v1"
    },
    "compatible_expflow_core": {
      "type": "string",
      "pattern": "^2\\.3(\\.\\d+)?$"
    },
    "continuity_mode": {
      "const": "reconstructed"
    },
    "identity_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material",
        "occupancy",
        "semantic"
      ],
      "properties": {
        "material": {
          "const": "stable_node_identity_plus_immutable_revision"
        },
        "occupancy": {
          "const": "relative_path_within_immutable_tree_revision"
        },
        "semantic": {
          "const": "assertion_plus_immutable_decision"
        }
      }
    },
    "revision_model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material_revision",
        "external_revision",
        "incremental_cursor"
      ],
      "properties": {
        "material_revision": {
          "const": "expflow_tree_revision"
        },
        "external_revision": {
          "const": "opaque_adapter_project_revision"
        },
        "incremental_cursor": {
          "const": "opaque_adapter_change_cursor"
        }
      }
    },
    "consistency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "material",
        "semantics",
        "projections",
        "post_commit_failure"
      ],
      "properties": {
        "material": {
          "const": "single_writer"
        },
        "semantics": {
          "const": "asynchronously_advancing"
        },
        "projections": {
          "const": "asynchronously_advancing"
        },
        "post_commit_failure": {
          "const": "material_success_automation_incomplete"
        }
      }
    },
    "observe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "inspect",
        "incremental_changes",
        "operation_resolution"
      ],
      "properties": {
        "status": {
          "const": true
        },
        "inspect": {
          "const": true
        },
        "incremental_changes": {
          "const": true
        },
        "operation_resolution": {
          "const": true
        }
      }
    },
    "act": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "init",
        "observational_sync",
        "mutating_sync",
        "restore",
        "projection_materialization",
        "regeneration"
      ],
      "properties": {
        "init": {
          "type": "boolean"
        },
        "observational_sync": {
          "type": "boolean"
        },
        "mutating_sync": {
          "type": "boolean"
        },
        "restore": {
          "type": "boolean"
        },
        "projection_materialization": {
          "type": "boolean"
        },
        "regeneration": {
          "type": "boolean"
        }
      }
    },
    "evaluate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "equivalence"
      ],
      "properties": {
        "equivalence": {
          "type": "boolean"
        }
      }
    },
    "reconcile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_lookup",
        "idempotent_replay",
        "recovery_inspection",
        "incremental_cursor"
      ],
      "properties": {
        "operation_lookup": {
          "const": true
        },
        "idempotent_replay": {
          "const": true
        },
        "recovery_inspection": {
          "const": true
        },
        "incremental_cursor": {
          "const": true
        }
      }
    },
    "unknown_outcomes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "regeneration",
          "interrupted_post_commit_automation",
          "lost_operation_response"
        ]
      },
      "uniqueItems": true
    },
    "writer_partition": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "boundary",
          "primary_writer",
          "other_access"
        ],
        "properties": {
          "boundary": {
            "type": "string"
          },
          "primary_writer": {
            "type": "string"
          },
          "other_access": {
            "type": "string"
          }
        }
      }
    }
  }
}
