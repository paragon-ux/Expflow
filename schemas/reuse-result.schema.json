{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/reuse-result.schema.json",
  "title": "Structural Workflow Reuse Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reuse_result_id",
    "project_id",
    "reference_workflow_occurrence_id",
    "reference_manifest_revision_id",
    "new_input_tree_revision_id",
    "status",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "reuse_result_id": {
      "type": "string",
      "pattern": "^efru_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "reference_workflow_occurrence_id": {
      "type": "string",
      "pattern": "^efw_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "reference_manifest_revision_id": {
      "type": "string",
      "pattern": "^efm_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "new_input_tree_revision_id": {
      "type": "string",
      "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "output_workflow_occurrence_id": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^efw_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "running",
        "completed",
        "failed",
        "rejected"
      ]
    },
    "deviation_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "semantic_leakage_evaluation_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "equivalence_evaluation_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_decision_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
