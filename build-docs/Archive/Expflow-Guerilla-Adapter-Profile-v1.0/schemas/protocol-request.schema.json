{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/adapters/guerilla/1.0/protocol-request.schema.json",
  "title": "Adapter Protocol Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_version",
    "request_id",
    "profile",
    "operation",
    "project_ref",
    "actor",
    "params"
  ],
  "properties": {
    "protocol_version": {
      "const": "1.0"
    },
    "request_id": {
      "type": "string",
      "pattern": "^egr_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "profile": {
      "const": "expflow.relative-tree.v1"
    },
    "operation": {
      "type": "string",
      "enum": [
        "project.inspect",
        "project.changes",
        "operation.resolve",
        "project.init",
        "project.sync",
        "evaluation.run"
      ]
    },
    "project_ref": {
      "type": "string",
      "minLength": 1
    },
    "expected_adapter_revision": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^epr_[0-9A-HJKMNP-TV-Z]{26}$"
        },
        {
          "type": "null"
        }
      ]
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Za-z0-9._:-]{1,128}$"
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "user",
            "agent",
            "integration",
            "system",
            "policy"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "params": {
      "type": "object"
    }
  }
}
