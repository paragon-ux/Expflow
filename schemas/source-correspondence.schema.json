{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://expflow.dev/schemas/2.3/source-correspondence.schema.json",
  "title": "Optional Import Source Correspondence Proposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "correspondence_id",
    "project_id",
    "source_record_ref",
    "candidate_entries",
    "evidence_refs",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "2.3"
    },
    "correspondence_id": {
      "type": "string",
      "pattern": "^efsc_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "project_id": {
      "type": "string",
      "pattern": "^efp_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "source_record_ref": {
      "type": "string"
    },
    "candidate_entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tree_revision_id",
          "relative_path",
          "node_id",
          "node_revision"
        ],
        "properties": {
          "tree_revision_id": {
            "type": "string",
            "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "relative_path": {
            "type": "string"
          },
          "node_id": {
            "type": "string",
            "pattern": "^efn_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "node_revision": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "proposed_selection": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tree_revision_id",
            "relative_path",
            "node_id",
            "node_revision"
          ],
          "properties": {
            "tree_revision_id": {
              "type": "string",
              "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
            },
            "relative_path": {
              "type": "string"
            },
            "node_id": {
              "type": "string",
              "pattern": "^efn_[0-9A-HJKMNP-TV-Z]{26}$"
            },
            "node_revision": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "unresolved_alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "tree_revision_id",
          "relative_path",
          "node_id",
          "node_revision"
        ],
        "properties": {
          "tree_revision_id": {
            "type": "string",
            "pattern": "^eft_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "relative_path": {
            "type": "string"
          },
          "node_id": {
            "type": "string",
            "pattern": "^efn_[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "node_revision": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
